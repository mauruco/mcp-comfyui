{
  "name": "mcp-comfyui",
  "version": "1.0.0",
  "description": "MCP HTTP Server for ComfyUI integration",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "start:debug": "MCP_DEBUG=true node index.js",
    "dev": "node index.js",
    "dev:debug": "MCP_DEBUG=true node index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "echo \"Linting not configured yet\"",
    "type-check": "node -c src/server/index.js && node -c src/models/flux-krea-t2i.js && node -c src/config/index.js"
  },
  "keywords": [
    "mcp",
    "comfyui",
    "ai",
    "image-generation",
    "server"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "axios": "^1.11.0"
  },
  "bin": {
    "mcp-comfyui": "./index.js"
  },
  "usage": {
    "start": "npm start",
    "custom-port": "node index.js --port 3000",
    "env-var": "MCP_SERVER_PORT=3000 npm start"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
